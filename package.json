{
  "name": "jib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["modules/*"],
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "build": "bun run build:jib",
    "build:jib": "bun build --compile apps/cli/main.ts --outfile dist/jib",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "dev": "bun run apps/cli/main.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@jib/deploy": "workspace:*",
    "@jib-module/cloudflared": "workspace:*",
    "@jib-module/github": "workspace:*",
    "@jib-module/nginx": "workspace:*",
    "@jib-module/watcher": "workspace:*",
    "@jib/config": "workspace:*",
    "@jib/core": "workspace:*",
    "@jib/docker": "workspace:*",
    "@jib/ingress": "workspace:*",
    "@jib/secrets": "workspace:*",
    "@jib/state": "workspace:*",
    "@jib/tui": "workspace:*",
    "@jib/sources": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "drizzle-orm": "^0.45.2",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  }
}
