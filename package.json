{
  "name": "deployjib",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hexnickk/jib"
  },
  "bin": {
    "jib": "dist/jib.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsup --entry.jib src/main.ts --format esm --platform node --target node22 --external better-sqlite3 --clean --no-splitting && chmod +x dist/jib.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "dev": "tsx src/main.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "better-sqlite3": "^12.11.1",
    "consola": "^3.2.3",
    "drizzle-orm": "^0.45.2",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0",
    "zod": "^3.23.8",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.0",
    "@types/yargs": "^17.0.35",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
